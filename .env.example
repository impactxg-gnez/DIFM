# Environment Variables

# Database (Supabase)
# Pooler: ok for the running app. Prisma "migrate deploy" uses DIRECT_URL (must not be the transaction pooler on :6543).
DATABASE_URL="postgresql://USER:PASS@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct: Supabase → Project Settings → Database → Connection string → URI, host db.xxxxx.supabase.co port 5432
DIRECT_URL="postgresql://USER:PASS@db.xxxxx.supabase.co:5432/postgres"

# Google Maps API Key (Required for location picker)
# Get your key from: https://console.cloud.google.com/
# Enable: Places API and Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
